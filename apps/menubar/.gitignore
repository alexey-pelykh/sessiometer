# Xcode / Swift build artifacts for the menu-bar app (apps/menubar/). The Rust
# crate's ignores live in the repo-root .gitignore; these are scoped here.

# Generated by `xcodegen generate` from project.yml — never committed.
*.xcodeproj

# Xcode build products / derived data
DerivedData/

# Swift Package Manager
.build/
.swiftpm/

# Per-user Xcode state (schemes, breakpoints, window layout)
xcuserdata/
